# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# ── Payload CMS ───────────────────────────────────────────────────────────────

# PostgreSQL connection string from Neon (neon.tech — free tier)
# Format: postgresql://user:password@host/dbname?sslmode=verify-ssl
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-ssl

# Random secret used to sign Payload tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your-random-secret-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to Vercel deployment URL in production (used by Payload for CORS)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
